<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpsT360.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#4357E8">

    <Grid Padding="30"
          RowDefinitions="Auto,*,Auto">

        <Label Grid.Row="0"
               Text="iT360° Application"
               TextColor="White"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,20,0,10" />

        <VerticalStackLayout Grid.Row="1"
                             Spacing="18"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">

            <Image Source="logo.png"
                   HeightRequest="180"
                   WidthRequest="180"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20" />

            <Border BackgroundColor="#E8E8E8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="16,8"
                    WidthRequest="300">
                <Entry Placeholder="Usuario"
                       Text="{Binding Username}"
                       BackgroundColor="Transparent"
                       TextColor="#30343B"
                       PlaceholderColor="#9AA4B1" />
            </Border>

            <Border BackgroundColor="#E8E8E8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="16,8"
                    WidthRequest="300">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Entry Placeholder="Password"
                           IsPassword="{Binding IsPasswordHidden}"
                           Text="{Binding Password}"
                           BackgroundColor="Transparent"
                           TextColor="#30343B"
                           PlaceholderColor="#9AA4B1" />

                    <Button Grid.Column="1"
                            Text="{Binding PasswordToggleGlyph}"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#6D7785"
                            WidthRequest="44"
                            HeightRequest="36"
                            Padding="0" />
                </Grid>
            </Border>

            <Button Text="Sign in"
                    WidthRequest="300"
                    HeightRequest="50"
                    CornerRadius="24"
                    BackgroundColor="{Binding SignInButtonColor}"
                    TextColor="White"
                    Clicked="OnSignInClicked" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="White"
                               Margin="0,8,0,0" />

            <Label Text="{Binding StatusMessage}"
                   TextColor="#FFE1E1"
                   HorizontalTextAlignment="Center"
                   WidthRequest="300"
                   Margin="0,10,0,0" />

            <VerticalStackLayout Spacing="6"
                                 Margin="0,20,0,0">
                <Label Text="Forgot your Password?"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Sign Up"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Cambiar Idioma"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>