<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpsT360.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource PrimaryBlue}">
    <Grid Padding="30" RowDefinitions="*,Auto,*">
        <VerticalStackLayout Grid.Row="1" Spacing="18" VerticalOptions="Center">
            <Image Source="logo-360.svg" HeightRequest="120" HorizontalOptions="Center" Margin="0,20,0,12" />

            <Border BackgroundColor="#E8E8E8" StrokeThickness="0" StrokeShape="RoundRectangle 24" Padding="16,8">
                <Entry Placeholder="Email"
                       Text="{Binding Username}"
                       BackgroundColor="Transparent"
                       TextColor="#30343B"
                       PlaceholderColor="#9AA4B1" />
            </Border>

            <Border BackgroundColor="#E8E8E8" StrokeThickness="0" StrokeShape="RoundRectangle 24" Padding="16,8">
                <Entry Placeholder="Password"
                       IsPassword="True"
                       Text="{Binding Password}"
                       BackgroundColor="Transparent"
                       TextColor="#30343B"
                       PlaceholderColor="#9AA4B1" />
            </Border>

            <Button Text="Sign in"
                    Command="{Binding LoginAsyncCommand}"
                    BackgroundColor="#D8DDE5"
                    TextColor="White"
                    CornerRadius="24"
                    HeightRequest="50" />

            <VerticalStackLayout Spacing="6" Margin="0,28,0,0">
                <Label Text="Forgot your Password?"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Sign Up"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Cambiar Idioma"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Label Text="{Binding StatusMessage}"
                   TextColor="#FFE1E1"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
