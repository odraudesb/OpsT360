<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpsT360.Views.SealInspectionPage"
             Title="iT360° Application"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F6F7FB">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="0,0,0,24">

            <Grid HeightRequest="84" Padding="14,26,14,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#3E5AF1">
                <Label Text="☰"
                       VerticalTextAlignment="Center"
                       TextColor="White"
                       FontSize="22" />
                <Label Grid.Column="1"
                       Text="{Binding OperationTitle}"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="20"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Center"
                       Margin="8,0" />
                <Image Grid.Column="2"
                       Source="logo.png"
                       HeightRequest="42"
                       WidthRequest="42"
                       Aspect="AspectFit"
                       HorizontalOptions="End"
                       VerticalOptions="Center" />
            </Grid>

            <VerticalStackLayout Spacing="14" Padding="16,0,16,0">

                <Border BackgroundColor="White" Stroke="#E2E4EC" StrokeShape="RoundRectangle 20" Padding="14,2">
                    <Entry Placeholder="Número Contenedor"
                           Text="{Binding ContainerId}"
                           BackgroundColor="Transparent"
                           TextColor="#3B4352"
                           PlaceholderColor="#A1A8B4"
                           HeightRequest="44" />
                </Border>

                <CollectionView ItemsSource="{Binding ContainerSuggestions}"
                                HeightRequest="90"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" BackgroundColor="#EEF3FF" Stroke="#D7E2FF" StrokeShape="RoundRectangle 10" Padding="10,8">
                                <Label Text="{Binding .}" TextColor="#24379E" FontAttributes="Bold">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectContainerCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="8">
                        <Button Text="Foto Panel 1"
                                FontAttributes="Bold"
                                HeightRequest="42"
                                CornerRadius="21"
                                BackgroundColor="#3E5AF1"
                                TextColor="White"
                                Command="{Binding LoadSealImageCommand}"
                                CommandParameter="1"
                                IsEnabled="{Binding CanUploadImages}" />
                        <Border BackgroundColor="#ECEEF3" Stroke="#DFE2E8" StrokeShape="RoundRectangle 10" HeightRequest="190">
                            <Image Source="{Binding SealImages[0].PreviewImage}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding SealImages[0].HasImage}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Button Text="Foto Panel 2"
                                FontAttributes="Bold"
                                HeightRequest="42"
                                CornerRadius="21"
                                BackgroundColor="#3E5AF1"
                                TextColor="White"
                                Command="{Binding LoadSealImageCommand}"
                                CommandParameter="2"
                                IsEnabled="{Binding CanUploadImages}" />
                        <Border BackgroundColor="#ECEEF3" Stroke="#DFE2E8" StrokeShape="RoundRectangle 10" HeightRequest="190">
                            <Image Source="{Binding SealImages[1].PreviewImage}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding SealImages[1].HasImage}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <Button Text="Leer Sellos"
                        HeightRequest="44"
                        CornerRadius="22"
                        FontAttributes="Bold"
                        BackgroundColor="#3E5AF1"
                        TextColor="White"
                        Clicked="OnReadNextSealClicked" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="14" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Border BackgroundColor="White" Stroke="#E2E4EC" StrokeShape="RoundRectangle 20" Padding="12,2">
                        <Entry x:Name="SealEntry1" Placeholder="Sello #1" Text="{Binding Seals[0].Code}" IsReadOnly="{Binding Seals[0].IsLocked}" Completed="OnSealCompleted" ClassId="1" BackgroundColor="Transparent" HeightRequest="42" TextColor="#3B4352" Focused="OnSealEntryFocused" />
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White" Stroke="#E2E4EC" StrokeShape="RoundRectangle 20" Padding="12,2">
                        <Entry x:Name="SealEntry2" Placeholder="Sello #2" Text="{Binding Seals[1].Code}" IsReadOnly="{Binding Seals[1].IsLocked}" Completed="OnSealCompleted" ClassId="2" BackgroundColor="Transparent" HeightRequest="42" TextColor="#3B4352" Focused="OnSealEntryFocused" />
                    </Border>
                    <Border Grid.Row="1" BackgroundColor="White" Stroke="#E2E4EC" StrokeShape="RoundRectangle 20" Padding="12,2">
                        <Entry x:Name="SealEntry3" Placeholder="Sello #3" Text="{Binding Seals[2].Code}" IsReadOnly="{Binding Seals[2].IsLocked}" Completed="OnSealCompleted" ClassId="3" BackgroundColor="Transparent" HeightRequest="42" TextColor="#3B4352" Focused="OnSealEntryFocused" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" Stroke="#E2E4EC" StrokeShape="RoundRectangle 20" Padding="12,2">
                        <Entry x:Name="SealEntry4" Placeholder="Sello #4" Text="{Binding Seals[3].Code}" IsReadOnly="{Binding Seals[3].IsLocked}" Completed="OnSealCompleted" ClassId="4" BackgroundColor="Transparent" HeightRequest="42" TextColor="#3B4352" Focused="OnSealEntryFocused" />
                    </Border>
                </Grid>

                <Button Text="Foto Contenedor"
                        FontAttributes="Bold"
                        HeightRequest="44"
                        CornerRadius="22"
                        BackgroundColor="#3E5AF1"
                        TextColor="White"
                        Command="{Binding LoadContainerImageCommand}"
                        IsEnabled="{Binding CanUploadImages}" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="End">
                    <Border BackgroundColor="#ECEEF3" Stroke="#DFE2E8" StrokeShape="RoundRectangle 10" HeightRequest="220" WidthRequest="220" HorizontalOptions="Center">
                        <Image Source="{Binding ContainerImage.PreviewImage}"
                               Aspect="AspectFill"
                               IsVisible="{Binding ContainerImage.HasImage}" />
                    </Border>
                    <Button Grid.Column="1"
                            Text="OK"
                            HeightRequest="48"
                            WidthRequest="84"
                            CornerRadius="24"
                            FontAttributes="Bold"
                            BackgroundColor="#3E5AF1"
                            TextColor="White"
                            VerticalOptions="End"
                            Command="{Binding SendCommand}"
                            IsEnabled="{Binding CanSend}" />
                </Grid>

                <Label Text="{Binding StatusText}"
                       FontSize="12"
                       TextColor="#6E7891" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
