<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpsT360.Views.SealInspectionPage"
             Title="iT360° Application"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F6F7FB">
    <Grid RowDefinitions="84,*" Padding="0,0,0,10">

        <Grid HeightRequest="84" Padding="14,26,14,12" ColumnDefinitions="Auto,*,Auto" BackgroundColor="#3E5AF1">
            <Label Text="☰"
                   VerticalTextAlignment="Center"
                   TextColor="White"
                   FontSize="22">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuTapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="1"
                   Text="{Binding OperationTitle}"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="18"
                   VerticalTextAlignment="Center"
                   HorizontalTextAlignment="Center"
                   Margin="8,0" />
            <Image Grid.Column="2"
                   Source="logo.png"
                   HeightRequest="42"
                   WidthRequest="42"
                   Aspect="AspectFit"
                   HorizontalOptions="End"
                   VerticalOptions="Center" />
        </Grid>

        <Grid Grid.Row="1" Padding="14,10,14,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="7">

            <Border Grid.Row="0" BackgroundColor="White" Stroke="#E2E4EC" StrokeShape="RoundRectangle 18" Padding="12,2">
                <Entry Placeholder="{Binding ContainerPlaceholder}"
                       Text="{Binding ContainerId}"
                       BackgroundColor="Transparent"
                       TextColor="#3B4352"
                       PlaceholderColor="#A1A8B4"
                       HeightRequest="40"
                       IsTextPredictionEnabled="False"
                       IsSpellCheckEnabled="False" />
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="{Binding Panel1ButtonText}"
                        FontAttributes="Bold"
                        HeightRequest="40"
                        CornerRadius="20"
                        BackgroundColor="#3E5AF1"
                        TextColor="White"
                        Command="{Binding LoadSealImageCommand}"
                        CommandParameter="1"
                        FontSize="14" />
                <Button Grid.Column="1"
                        Text="{Binding Panel2ButtonText}"
                        FontAttributes="Bold"
                        HeightRequest="40"
                        CornerRadius="20"
                        BackgroundColor="#3E5AF1"
                        TextColor="White"
                        Command="{Binding LoadSealImageCommand}"
                        CommandParameter="2"
                        FontSize="14" />
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border BackgroundColor="#ECEEF3" Stroke="#DFE2E8" StrokeShape="RoundRectangle 10" HeightRequest="114">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPanelPreviewTapped" CommandParameter="1" />
                    </Border.GestureRecognizers>
                    <Image Source="{Binding SealImages[0].PreviewImage}"
                           Aspect="AspectFill"
                           IsVisible="{Binding SealImages[0].HasImage}" />
                </Border>
                <Border Grid.Column="1" BackgroundColor="#ECEEF3" Stroke="#DFE2E8" StrokeShape="RoundRectangle 10" HeightRequest="114">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPanelPreviewTapped" CommandParameter="2" />
                    </Border.GestureRecognizers>
                    <Image Source="{Binding SealImages[1].PreviewImage}"
                           Aspect="AspectFill"
                           IsVisible="{Binding SealImages[1].HasImage}" />
                </Border>
            </Grid>

            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10">
                <Border Padding="8,4" Stroke="#E1E5EE" BackgroundColor="White" StrokeShape="RoundRectangle 10">
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Label FontSize="13" VerticalTextAlignment="Center" Text="⏸">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding SealImages[0].ValidationStatus}" Value="success">
                                    <Setter Property="Text" Value="✓" />
                                    <Setter Property="TextColor" Value="#16A34A" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding SealImages[0].ValidationStatus}" Value="failed">
                                    <Setter Property="Text" Value="✗" />
                                    <Setter Property="TextColor" Value="#DC2626" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding SealImages[0].ValidationStatus}" Value="pending">
                                    <Setter Property="Text" Value="⏳" />
                                    <Setter Property="TextColor" Value="#2563EB" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label FontSize="12"
                               LineBreakMode="TailTruncation"
                               Text="{Binding Panel1StatusText}"
                               TextColor="{Binding Panel1StatusColor}" />
                    </HorizontalStackLayout>
                </Border>

                <Border Grid.Column="1" Padding="8,4" Stroke="#E1E5EE" BackgroundColor="White" StrokeShape="RoundRectangle 10">
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Label FontSize="13" VerticalTextAlignment="Center" Text="⏸">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding SealImages[1].ValidationStatus}" Value="success">
                                    <Setter Property="Text" Value="✓" />
                                    <Setter Property="TextColor" Value="#16A34A" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding SealImages[1].ValidationStatus}" Value="failed">
                                    <Setter Property="Text" Value="✗" />
                                    <Setter Property="TextColor" Value="#DC2626" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding SealImages[1].ValidationStatus}" Value="pending">
                                    <Setter Property="Text" Value="⏳" />
                                    <Setter Property="TextColor" Value="#2563EB" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label FontSize="12"
                               LineBreakMode="TailTruncation"
                               Text="{Binding Panel2StatusText}"
                               TextColor="{Binding Panel2StatusColor}" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <Border Grid.Row="4" Padding="8,4" Stroke="#E1E5EE" BackgroundColor="White" StrokeShape="RoundRectangle 10">
                <Label Text="{Binding PanelValidationSummary}"
                       TextColor="{Binding PanelValidationSummaryColor}"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="TailTruncation" />
            </Border>

            <VerticalStackLayout Grid.Row="5" Spacing="4">
                <Button Text="{Binding ReadSealsButtonText}"
                        HeightRequest="38"
                        CornerRadius="20"
                        FontAttributes="Bold"
                        BackgroundColor="#3E5AF1"
                        TextColor="White"
                        Clicked="OnReadNextSealClicked" />
                <Label Text="{Binding StatusText}"
                       FontSize="11"
                       TextColor="#4B5563"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Grid Grid.Row="6" ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="7">
                <Border BackgroundColor="#E7E9EE" Stroke="#D9DEE8" StrokeShape="RoundRectangle 16" Padding="10,2">
                    <Entry x:Name="SealEntry1" Placeholder="{Binding Seal1Placeholder}" Text="{Binding Seals[0].Code}" IsReadOnly="True" IsEnabled="False" BackgroundColor="Transparent" HeightRequest="38" TextColor="#596274" />
                </Border>
                <Border Grid.Column="1" BackgroundColor="#E7E9EE" Stroke="#D9DEE8" StrokeShape="RoundRectangle 16" Padding="10,2">
                    <Entry x:Name="SealEntry2" Placeholder="{Binding Seal2Placeholder}" Text="{Binding Seals[1].Code}" IsReadOnly="True" IsEnabled="False" BackgroundColor="Transparent" HeightRequest="38" TextColor="#596274" />
                </Border>
                <Border Grid.Row="1" BackgroundColor="#E7E9EE" Stroke="#D9DEE8" StrokeShape="RoundRectangle 16" Padding="10,2">
                    <Entry x:Name="SealEntry3" Placeholder="{Binding Seal3Placeholder}" Text="{Binding Seals[2].Code}" IsReadOnly="True" IsEnabled="False" BackgroundColor="Transparent" HeightRequest="38" TextColor="#596274" />
                </Border>
                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#E7E9EE" Stroke="#D9DEE8" StrokeShape="RoundRectangle 16" Padding="10,2">
                    <Entry x:Name="SealEntry4" Placeholder="{Binding Seal4Placeholder}" Text="{Binding Seals[3].Code}" IsReadOnly="True" IsEnabled="False" BackgroundColor="Transparent" HeightRequest="38" TextColor="#596274" />
                </Border>
            </Grid>

            <Grid Grid.Row="7" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                <Button Grid.Row="0"
                        Text="{Binding ContainerPhotoButtonText}"
                        FontAttributes="Bold"
                        HeightRequest="38"
                        CornerRadius="20"
                        BackgroundColor="#3E5AF1"
                        TextColor="White"
                        Command="{Binding LoadContainerImageCommand}" />

                <Border Grid.Row="1" BackgroundColor="#ECEEF3" Stroke="#DFE2E8" StrokeShape="RoundRectangle 10" HeightRequest="108" WidthRequest="152" HorizontalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnContainerPreviewTapped" />
                    </Border.GestureRecognizers>
                    <Image Source="{Binding ContainerImage.PreviewImage}"
                           Aspect="AspectFill"
                           IsVisible="{Binding ContainerImage.HasImage}" />
                </Border>

                <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="10">
                    <Button Text="OK"
                            HeightRequest="42"
                            WidthRequest="120"
                            CornerRadius="22"
                            FontAttributes="Bold"
                            BackgroundColor="#3E5AF1"
                            TextColor="White"
                            Command="{Binding SendCommand}" />
                    <Button Text="Limpiar"
                            HeightRequest="42"
                            WidthRequest="120"
                            CornerRadius="22"
                            FontAttributes="Bold"
                            BackgroundColor="#6B7280"
                            TextColor="White"
                            Command="{Binding ResetTransactionCommand}" />
                </HorizontalStackLayout>
            </Grid>

        </Grid>

        <Grid Grid.RowSpan="2"
              BackgroundColor="#66000000"
              IsVisible="{Binding IsProcessing}"
              InputTransparent="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Spacing="10"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsProcessing}"
                                   Color="White"
                                   WidthRequest="42"
                                   HeightRequest="42" />
                <Label Text="{Binding ProcessingText}"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
