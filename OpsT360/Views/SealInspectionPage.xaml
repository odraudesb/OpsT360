<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpsT360.Views.SealInspectionPage"
             Title="RFID Seals Activation"
             BackgroundColor="#E9E9EB">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="8">
            <Label Text="APP T360 COLOCACION SELLOS RFID"
                   FontSize="18"
                   TextColor="#B3B3B8"
                   FontAttributes="Bold" />

            <Frame BackgroundColor="#F7F7F8" CornerRadius="0" BorderColor="#F7F7F8" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="RFID Seals Activation" FontSize="52" FontAttributes="Bold" TextColor="#1F2430" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Container Id" TextColor="#6A7786" />
                            <Entry Placeholder=""
                                   Text="{Binding ContainerId}"
                                   BackgroundColor="#ECEDEF"
                                   HeightRequest="48" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Activation Point" TextColor="#6A7786" />
                            <Picker ItemsSource="{Binding ActivationPoints}"
                                    SelectedItem="{Binding SelectedActivationPoint}"
                                    BackgroundColor="#ECEDEF"
                                    HeightRequest="48" />
                        </VerticalStackLayout>
                    </Grid>

                    <CollectionView ItemsSource="{Binding ContainerSuggestions}" HeightRequest="70">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" Padding="6" BackgroundColor="WhiteSmoke">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectContainerCommand}" CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="RFID Seal registry" FontSize="22" FontAttributes="Bold" TextColor="#1F2430" />
                    <BoxView HeightRequest="1" Color="#D2D4DA" />

                    <Label Text="Seal # 1" TextColor="#6A7786" />
                    <Entry x:Name="SealEntry1" Text="{Binding Seals[0].Code}" IsReadOnly="{Binding Seals[0].IsLocked}" Completed="OnSealCompleted" ClassId="1" BackgroundColor="#ECEDEF" HeightRequest="48" Focused="OnSealEntryFocused"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="✓  Read Seal #1" BackgroundColor="#97A5B8" TextColor="White" ClassId="1" Clicked="OnReadSealClicked" />
                        <Button Text="🖼  Seal Image #1" BackgroundColor="#97A5B8" TextColor="White" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="1" />
                    </Grid>

                    <Label Text="Seal # 2" TextColor="#6A7786" />
                    <Entry x:Name="SealEntry2" Text="{Binding Seals[1].Code}" IsReadOnly="{Binding Seals[1].IsLocked}" Completed="OnSealCompleted" ClassId="2" BackgroundColor="#ECEDEF" HeightRequest="48" Focused="OnSealEntryFocused"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="📶  Read Seal #2" BackgroundColor="#4357E8" TextColor="White" ClassId="2" Clicked="OnReadSealClicked" />
                        <Button Text="🖼  Seal Image #2" BackgroundColor="#4357E8" TextColor="White" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="2" />
                    </Grid>

                    <Label Text="Seal # 3" TextColor="#6A7786" />
                    <Entry x:Name="SealEntry3" Text="{Binding Seals[2].Code}" IsReadOnly="{Binding Seals[2].IsLocked}" Completed="OnSealCompleted" ClassId="3" BackgroundColor="#ECEDEF" HeightRequest="48" Focused="OnSealEntryFocused"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="📶  Read Seal #3" BackgroundColor="#4357E8" TextColor="White" ClassId="3" Clicked="OnReadSealClicked" />
                        <Button Text="🖼  Seal Image #3" BackgroundColor="#4357E8" TextColor="White" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="3" />
                    </Grid>

                    <Label Text="Seal # 4" TextColor="#6A7786" />
                    <Entry x:Name="SealEntry4" Text="{Binding Seals[3].Code}" IsReadOnly="{Binding Seals[3].IsLocked}" Completed="OnSealCompleted" ClassId="4" BackgroundColor="#ECEDEF" HeightRequest="48" Focused="OnSealEntryFocused"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="📶  Read Seal #4" BackgroundColor="#4357E8" TextColor="White" ClassId="4" Clicked="OnReadSealClicked" />
                        <Button Text="🖼  Seal Image #4" BackgroundColor="#4357E8" TextColor="White" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="4" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#D2D4DA" Margin="0,6,0,0" />

                    <Label Text="Container image evidence" FontSize="18" FontAttributes="Bold" TextColor="#536173" />
                    <Button Text="🖼  Contr. Image" BackgroundColor="#4357E8" TextColor="White" Command="{Binding LoadContainerImageAsyncCommand}" />

                    <BoxView HeightRequest="1" Color="#D2D4DA" Margin="0,8,0,0" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14" Margin="0,8,0,0">
                        <Button Text="Cancel" BackgroundColor="#EFF0F3" TextColor="#1E2433" Command="{Binding CancelCommand}" />
                        <Button Text="✈  Send" BackgroundColor="#0E1730" TextColor="White" Command="{Binding SendAsyncCommand}" />
                    </Grid>

                    <Button Text="Editar / Reemplazar" BackgroundColor="#78859B" TextColor="White" Command="{Binding ToggleEditModeCommand}" />
                    <Label Text="{Binding StatusText}" FontAttributes="Bold" TextColor="#536173" />
                    <Label Text="Hand-held: el lector infrarrojo/RFID envía el código como teclado al campo enfocado."
                           FontSize="12"
                           TextColor="#6A7786" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
