<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpsT360.Views.SealInspectionPage"
             Title="RFID Seals Activation"
             BackgroundColor="#F3F5FB">
    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,28" Spacing="14">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border BackgroundColor="#24379E" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10">
                    <Label Text="RFID" TextColor="White" FontAttributes="Bold" FontSize="12" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="OPS T360" FontSize="12" TextColor="#6E7891" FontAttributes="Bold" />
                    <Label Text="RFID Seals Activation" FontSize="24" FontAttributes="Bold" TextColor="#1C2537" />
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="White" Stroke="#E2E8F3" StrokeShape="RoundRectangle 16" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Container information" FontAttributes="Bold" TextColor="#2B3852" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Container Id" TextColor="#6E7891" FontSize="12" />
                            <Entry Placeholder="Ej: HSU3523430"
                                   Text="{Binding ContainerId}"
                                   BackgroundColor="#F1F4FA"
                                   TextColor="#243048"
                                   HeightRequest="46" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Activation Point" TextColor="#6E7891" FontSize="12" />
                            <Picker ItemsSource="{Binding ActivationPoints}"
                                    SelectedItem="{Binding SelectedActivationPoint}"
                                    BackgroundColor="#F1F4FA"
                                    TextColor="#243048"
                                    HeightRequest="46" />
                        </VerticalStackLayout>
                    </Grid>

                    <CollectionView ItemsSource="{Binding ContainerSuggestions}"
                                    HeightRequest="120"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" BackgroundColor="#EEF3FF" Stroke="#D7E2FF" StrokeShape="RoundRectangle 10" Padding="10,8">
                                    <Label Text="{Binding .}" TextColor="#24379E" FontAttributes="Bold">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectContainerCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#E2E8F3" StrokeShape="RoundRectangle 16" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="RFID seal registry" FontAttributes="Bold" TextColor="#2B3852" />
                    <Label Text="Pulsa Read Seal y luego gatillo del hand-held."
                           FontSize="12"
                           TextColor="#6E7891" />

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Entry x:Name="SealEntry1" Placeholder="Seal #1" Text="{Binding Seals[0].Code}" IsReadOnly="{Binding Seals[0].IsLocked}" Completed="OnSealCompleted" ClassId="1" BackgroundColor="#F1F4FA" HeightRequest="46" TextColor="#243048" Focused="OnSealEntryFocused"/>
                        <Button Grid.Column="1" Text="Read" ClassId="1" Clicked="OnReadSealClicked" BackgroundColor="#4357E8" WidthRequest="76" />
                        <Button Grid.Column="2" Text="Image" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="1" IsEnabled="{Binding CanUploadImages}" BackgroundColor="#24379E" WidthRequest="76" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Entry x:Name="SealEntry2" Placeholder="Seal #2" Text="{Binding Seals[1].Code}" IsReadOnly="{Binding Seals[1].IsLocked}" Completed="OnSealCompleted" ClassId="2" BackgroundColor="#F1F4FA" HeightRequest="46" TextColor="#243048" Focused="OnSealEntryFocused"/>
                        <Button Grid.Column="1" Text="Read" ClassId="2" Clicked="OnReadSealClicked" BackgroundColor="#4357E8" WidthRequest="76" />
                        <Button Grid.Column="2" Text="Image" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="2" IsEnabled="{Binding CanUploadImages}" BackgroundColor="#24379E" WidthRequest="76" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Entry x:Name="SealEntry3" Placeholder="Seal #3" Text="{Binding Seals[2].Code}" IsReadOnly="{Binding Seals[2].IsLocked}" Completed="OnSealCompleted" ClassId="3" BackgroundColor="#F1F4FA" HeightRequest="46" TextColor="#243048" Focused="OnSealEntryFocused"/>
                        <Button Grid.Column="1" Text="Read" ClassId="3" Clicked="OnReadSealClicked" BackgroundColor="#4357E8" WidthRequest="76" />
                        <Button Grid.Column="2" Text="Image" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="3" IsEnabled="{Binding CanUploadImages}" BackgroundColor="#24379E" WidthRequest="76" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Entry x:Name="SealEntry4" Placeholder="Seal #4" Text="{Binding Seals[3].Code}" IsReadOnly="{Binding Seals[3].IsLocked}" Completed="OnSealCompleted" ClassId="4" BackgroundColor="#F1F4FA" HeightRequest="46" TextColor="#243048" Focused="OnSealEntryFocused"/>
                        <Button Grid.Column="1" Text="Read" ClassId="4" Clicked="OnReadSealClicked" BackgroundColor="#4357E8" WidthRequest="76" />
                        <Button Grid.Column="2" Text="Image" Command="{Binding LoadSealImageAsyncCommand}" CommandParameter="4" IsEnabled="{Binding CanUploadImages}" BackgroundColor="#24379E" WidthRequest="76" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,6,0,0">
                        <Label Text="Container image" VerticalTextAlignment="Center" TextColor="#2B3852" FontAttributes="Bold"/>
                        <Button Grid.Column="1" Text="Upload" Command="{Binding LoadContainerImageAsyncCommand}" IsEnabled="{Binding CanUploadImages}" BackgroundColor="#24379E" WidthRequest="90" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Stroke="#E2E8F3" StrokeShape="RoundRectangle 16" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Status" FontAttributes="Bold" TextColor="#2B3852" />
                    <Label Text="{Binding StatusText}" TextColor="#4C5B76" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Editar / Reemplazar"
                                BackgroundColor="#6D7A92"
                                Command="{Binding ToggleEditModeCommand}" />
                        <Button Grid.Column="1"
                                Text="Send"
                                BackgroundColor="#11192C"
                                IsEnabled="{Binding CanSend}"
                                Command="{Binding SendAsyncCommand}" />
                    </Grid>

                    <Button Text="Cancel"
                            BackgroundColor="#EBEEF5"
                            TextColor="#22304A"
                            Command="{Binding CancelCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
