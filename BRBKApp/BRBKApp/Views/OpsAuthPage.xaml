<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BRBKApp.Views.OpsAuthPage"
             Title="OpsT360 - Acceso"
             BackgroundColor="#f2f2f2">
    <ScrollView>
        <StackLayout Padding="20" Spacing="16">
            <Label Text="OpsT360" FontSize="28" FontAttributes="Bold" TextColor="#111827" />
            <Label Text="Pantallas de acceso (Login, Sign up, Olvidé contraseña)" TextColor="#6B7280" />

            <Frame CornerRadius="12" Padding="16" BackgroundColor="#3E55E8" HasShadow="False">
                <StackLayout Spacing="10">
                    <Label Text="Sign up" TextColor="White" FontSize="20" HorizontalOptions="Center" />
                    <Entry Placeholder="Email" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Name" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Last Name" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Company" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Password" IsPassword="True" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Confirm Password" IsPassword="True" BackgroundColor="White" HeightRequest="40" />
                    <Button Text="Sign up" CornerRadius="8" BackgroundColor="#C7D2FE" TextColor="#1E3A8A" />
                </StackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="16" BackgroundColor="#3E55E8" HasShadow="False">
                <StackLayout Spacing="10">
                    <Label Text="Sign in" TextColor="White" FontSize="20" HorizontalOptions="Center" />
                    <Entry Placeholder="Email" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Password" IsPassword="True" BackgroundColor="White" HeightRequest="40" />
                    <Button Text="Sign in" CornerRadius="8" BackgroundColor="#C7D2FE" TextColor="#1E3A8A" />
                    <Label Text="Forgot your password?" TextColor="White" HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="16" BackgroundColor="#3E55E8" HasShadow="False">
                <StackLayout Spacing="10">
                    <Label Text="I forgot my password" TextColor="White" FontSize="20" HorizontalOptions="Center" />
                    <Entry Placeholder="Enter your email" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Verification Code" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="New Password" IsPassword="True" BackgroundColor="White" HeightRequest="40" />
                    <Entry Placeholder="Confirm New Password" IsPassword="True" BackgroundColor="White" HeightRequest="40" />
                    <Button Text="Continue" CornerRadius="8" BackgroundColor="#C7D2FE" TextColor="#1E3A8A" />
                </StackLayout>
            </Frame>
        </StackLayout>
    </ScrollView>
</ContentPage>
