<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:behaviors="http://xamarin.com/schemas/2020/toolkit"
             Title="{Binding Title}"
             x:Class="BRBKApp.Views.VBSAddAisvExternalPage">
    <!--<Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding CancelCommand}">
            <BackButtonBehavior.TextOverride>
                <OnPlatform x:TypeArguments="x:String">
                    <OnPlatform.Platforms>
                        <On Platform="iOS" Value="Go Back" />
                    </OnPlatform.Platforms>
                </OnPlatform>
            </BackButtonBehavior.TextOverride>
        </BackButtonBehavior>
    </Shell.BackButtonBehavior>-->
    <ContentPage.Content>
        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <StackLayout>
                    <FlexLayout Padding="15" Direction="Column" FlexLayout.Grow="1">
                        <Frame BorderColor="{StaticResource Light}"
                           CornerRadius="10"
                           HasShadow="True">
                            <StackLayout Spacing="3" Padding="15">

                                <Grid IsEnabled="True" >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Row="0" Style="{StaticResource LabelStyle}" Text="Vessel" />
                                    <Picker Grid.Row="0" Grid.Column="1" HorizontalOptions="FillAndExpand" 
                                            FontSize="Small" 
                                            BackgroundColor="{StaticResource Light}" 
                                            Title="--Select--" 
                                            ItemsSource="{Binding ListNaves}" 
                                            ItemDisplayBinding="{Binding Descripcion}" 
                                            SelectedItem="{Binding SelectedNave}"
                                            TextColor="Black">

                                    </Picker>
                                    <Label Grid.Row="1" Style="{StaticResource LabelStyle}" Text="Hold" />
                                    <Picker Grid.Row="1" Grid.Column="1" HorizontalOptions="FillAndExpand" 
                                            FontSize="Small" 
                                            BackgroundColor="{StaticResource Light}" 
                                            Title="--Select--" 
                                            ItemsSource="{Binding ListHolds}" 
                                            ItemDisplayBinding="{Binding Descripcion}" 
                                            SelectedItem="{Binding SelectedHold}"
                                            TextColor="Black">

                                    </Picker>

                                    <Label Grid.Row="2" Style="{StaticResource LabelStyle}" Text="Store" />
                                    <Picker Grid.Row="2" Grid.Column="1" HorizontalOptions="FillAndExpand" 
                                            FontSize="Small" 
                                            SelectedIndexChanged="Picker_SelectedIndexChanged"
                                            BackgroundColor="{StaticResource Light}" 
                                            Title="--Select--" 
                                            ItemsSource="{Binding ListBodegas}" 
                                            ItemDisplayBinding="{Binding Descripcion}" 
                                            SelectedItem="{Binding SelectedBodega}"
                                            TextColor="Black">

                                    </Picker>

                                    <Label Grid.Row="3" Style="{StaticResource LabelStyle}" Text="Block" />
                                    <Picker Grid.Row="3" Grid.Column="1" HorizontalOptions="FillAndExpand" 
                                            FontSize="Small" 
                                            BackgroundColor="{StaticResource Light}" 
                                            Title="--Select--" 
                                            ItemsSource="{Binding ListBloques}" 
                                            ItemDisplayBinding="{Binding Descripcion}" 
                                            SelectedItem="{Binding SelectedBloque}"
                                            TextColor="Black">

                                    </Picker>

                                    <Label Grid.Row="4" Style="{StaticResource LabelStyle}" Text="AISV" />
                                    <Editor x:Name="txtAisv" Grid.Row="4" Grid.Column="1" FontSize="Small" Text="{Binding BarcodeEntry,Mode=TwoWay}" Keyboard="Text" AutoSize="TextChanges" MaxLength="50" TextColor="Black" BackgroundColor="{StaticResource Light}" />

                                </Grid>

                                <StackLayout Padding="0,20,0,0" Orientation="Horizontal">
                                    <Button Text="Cancel" Command="{Binding CancelCommand}"  BorderRadius="20" HorizontalOptions="FillAndExpand"></Button>
                                    <Button Text="Save" Command="{Binding SaveChangesCommand}" BorderRadius="20" HorizontalOptions="FillAndExpand"></Button>
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </FlexLayout>
                </StackLayout>
            </ScrollView>
        </RefreshView>
    </ContentPage.Content>
</ContentPage>